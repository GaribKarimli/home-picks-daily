---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
const siteTitle = title.includes('Home Finds') ? title : `${title} — Home Finds`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{siteTitle}</title>
    <meta name="description" content={description || 'Discover the best home and kitchen products. Curated finds for your modern home.'} />

    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description || 'Curated home and kitchen products.'} />
    {image && <meta property="og:image" content={image} />}
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description || 'Curated home and kitchen products.'} />
    {image && <meta name="twitter:image" content={image} />}
  </head>
  <body class="flex flex-col min-h-screen">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
