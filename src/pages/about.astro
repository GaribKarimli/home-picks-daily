---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="Learn more about Home Finds and our affiliate relationships.">
  <div class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-3xl md:text-4xl font-display font-bold text-dark mb-8">About Home Finds</h1>

    <div class="prose prose-gray max-w-none
      prose-headings:font-display prose-headings:text-dark
      prose-p:text-secondary prose-p:leading-relaxed
      prose-a:text-dark prose-a:underline
      prose-strong:text-dark">
      <p>
        Welcome to <strong>Home Finds</strong> — your curated destination for the best home and kitchen products.
      </p>

      <p>
        Our team scours the market to find products that combine quality, design, and value. From innovative kitchen gadgets to cozy living room decor and clever organization solutions, every product on this site has been handpicked with care.
      </p>

      <h2>Affiliate Disclosure</h2>
      <p>
        Home Finds is a participant in the Amazon Services LLC Associates Program, an affiliate advertising program designed to provide a means for sites to earn advertising fees by advertising and linking to <a href="https://www.amazon.com" target="_blank" rel="noopener">Amazon.com</a>.
      </p>
      <p>
        As an Amazon Associate, we earn from qualifying purchases. If you click on a link to a product on our site and make a purchase on Amazon, we may receive a small commission at no additional cost to you.
      </p>
    </div>
  </div>
</BaseLayout>
