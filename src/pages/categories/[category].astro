---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import ProductCard from '../../components/ProductCard.astro';

export async function getStaticPaths() {
  const niches = {
    'home-decor': { name: 'Home Decor', description: 'Beautiful accents to elevate your living space.' },
    'tech-gadgets': { name: 'Tech Gadgets', description: 'Smart devices for the modern lifestyle.' },
    'fitness-equipment': { name: 'Fitness Equipment', description: 'Gear that keeps you moving.' },
    'kitchen-essentials': { name: 'Kitchen Essentials', description: 'Tools every home cook needs.' },
  };
  return Object.entries(niches).map(([slug, info]) => ({
    params: { category: slug },
    props: { nicheSlug: slug, nicheInfo: info },
  }));
}

const { nicheSlug, nicheInfo } = Astro.props;
const allPosts = await getCollection('posts');
const posts = allPosts.filter(p => p.data.niche === nicheSlug);
posts.sort((a, b) => {
  const aHasImage = a.data.image ? 1 : 0;
  const bHasImage = b.data.image ? 1 : 0;
  if (aHasImage !== bHasImage) return bHasImage - aHasImage;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
---

<BaseLayout
  title={nicheInfo.name}
  description={`Browse our collection of ${nicheInfo.name.toLowerCase()}. ${nicheInfo.description}`}
>
  <div class="max-w-6xl mx-auto px-4 py-16">
    <nav class="text-sm text-dark/40 mb-8 font-sans flex flex-wrap items-center gap-x-2 gap-y-1">
      <a href="/" class="hover:text-brand-500 transition-colors">Home</a>
      <span>/</span>
      <a href="/categories/" class="hover:text-brand-500 transition-colors">Categories</a>
      <span>/</span>
      <span class="text-dark/70 font-medium">{nicheInfo.name}</span>
    </nav>

    <h1 class="text-3xl md:text-4xl font-display font-bold text-dark mb-2">{nicheInfo.name}</h1>
    <p class="text-dark/50 mb-12">{nicheInfo.description}</p>

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {posts.map(post => <ProductCard post={post} />)}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-dark/40 text-lg">No products in this niche yet.</p>
        <p class="text-dark/30 text-sm mt-2">Check back soon for new additions!</p>
        <a href="/" class="inline-block mt-6 text-accent-500 font-medium hover:text-accent-600 transition-colors">
          &larr; Back to Home
        </a>
      </div>
    )}
  </div>
</BaseLayout>
