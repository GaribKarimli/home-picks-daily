---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { data } = post;
const { Content } = await post.render();
const stars = Math.round(data.rating);
const categorySlug = data.category.toLowerCase().replace(/\s+/g, '-');
---

<BaseLayout title={data.title} description={data.description} image={data.image}>
  <article class="max-w-4xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-400 mb-6">
      <a href="/" class="hover:text-brand-500 transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href={`/categories/${categorySlug}/`} class="hover:text-brand-500 transition-colors">{data.category}</a>
      <span class="mx-2">/</span>
      <span class="text-dark font-medium">{data.title}</span>
    </nav>

    <div class="grid md:grid-cols-2 gap-8 md:gap-12">
      <div class="rounded-2xl overflow-hidden bg-brand-50">
        <img src={data.image} alt={data.title} class="w-full h-auto object-cover" />
      </div>

      <div class="flex flex-col">
        <span class="inline-block text-xs font-medium text-brand-600 bg-brand-50 px-3 py-1.5 rounded-full w-fit">
          {data.category}
        </span>

        <h1 class="text-3xl md:text-4xl font-bold text-dark mt-3 leading-tight">
          {data.title}
        </h1>

        <div class="flex items-center gap-2 mt-3">
          <div class="flex text-amber-400 text-lg">
            {Array.from({ length: 5 }, (_, i) => (
              <span>{i < stars ? '★' : '☆'}</span>
            ))}
          </div>
          <span class="text-sm text-gray-400">{data.rating} / 5</span>
        </div>

        <p class="text-3xl font-bold text-brand-600 mt-4">{data.price}</p>

        <ul class="mt-6 space-y-3">
          {data.features.map((feature, i) => (
            <li class="flex items-start gap-3 text-gray-600">
              <svg class="w-5 h-5 text-brand-500 mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
              </svg>
              {feature}
            </li>
          ))}
        </ul>

        <div class="mt-auto pt-8">
          <a
            href={data.amazonLink}
            target="_blank"
            rel="noopener sponsored"
            class="block w-full text-center bg-brand-500 hover:bg-brand-600 text-white font-semibold py-4 px-6 rounded-xl text-lg transition-all duration-300 shadow-md hover:shadow-lg active:scale-[0.98]"
          >
            Check Price on Amazon &rarr;
          </a>
          <p class="mt-2 text-xs text-gray-400 text-center">
            As an Amazon Associate we earn from qualifying purchases.
          </p>
        </div>
      </div>
    </div>

    <div class="mt-12 md:mt-16 max-w-3xl">
      <div class="prose prose-gray prose-lg">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
