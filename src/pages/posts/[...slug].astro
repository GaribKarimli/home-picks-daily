---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { data } = post;
const { Content } = await post.render();
---

<BaseLayout title={data.title} description={data.description} image={data.image}>
  <article class="max-w-4xl mx-auto px-4 py-10">
    <nav class="text-xs text-secondary mb-8 font-sans flex flex-wrap items-center gap-x-2 gap-y-1">
      <a href="/" class="hover:text-dark transition-colors">Catalog</a>
      <span>/</span>
      <a href={`/?niche=${data.niche}`} class="hover:text-dark transition-colors">{data.category}</a>
      <span>/</span>
      <span class="text-dark font-medium">{data.title}</span>
    </nav>

    <div class="grid md:grid-cols-2 gap-10 md:gap-14">
      <div class="overflow-hidden bg-cream">
        <img src={data.image} alt={data.title} class="w-full h-auto object-cover" />
      </div>

      <div class="flex flex-col">
        <h1 class="text-3xl md:text-4xl font-display font-bold text-dark mt-4 leading-tight">
          {data.title}
        </h1>

        <p class="text-3xl md:text-4xl font-display font-bold text-dark mt-5">{data.price}</p>

        <ul class="mt-6 space-y-3">
          {data.features.map((feature) => (
            <li class="flex items-start gap-3 text-secondary">
              <svg class="w-5 h-5 text-dark mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
              </svg>
              {feature}
            </li>
          ))}
        </ul>

        <div class="mt-auto pt-8">
          <a
            href={data.amazonLink}
            target="_blank"
            rel="noopener sponsored"
            class="block w-full text-center bg-dark text-white font-medium text-sm uppercase tracking-widest py-4 px-6 transition-all duration-300 hover:opacity-90 active:scale-[0.98]"
          >
            Check Price on Amazon &rarr;
          </a>
          <p class="mt-2 text-xs text-secondary text-center">
            As an Amazon Associate we earn from qualifying purchases.
          </p>
        </div>
      </div>
    </div>

    <div class="mt-14 md:mt-20 max-w-3xl">
      <div class="prose prose-gray prose-lg max-w-none
        prose-headings:font-display prose-headings:text-dark
        prose-p:text-secondary prose-p:leading-relaxed
        prose-a:text-dark prose-a:no-underline hover:prose-a:underline
        prose-strong:text-dark
        prose-li:text-secondary">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
