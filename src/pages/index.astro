---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import ProductCard from '../components/ProductCard.astro';
import CategoryCard from '../components/CategoryCard.astro';
import CategoryTabs from '../components/CategoryTabs.astro';

const allPosts = await getCollection('posts');
allPosts.sort((a, b) => {
  const aHasImage = a.data.image ? 1 : 0;
  const bHasImage = b.data.image ? 1 : 0;
  if (aHasImage !== bHasImage) return bHasImage - aHasImage;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

const categories = [
  { name: 'Home Decor', slug: 'home-decor', description: 'Beautiful accents to elevate your living space' },
  { name: 'Tech Gadgets', slug: 'tech-gadgets', description: 'Smart devices for the modern lifestyle' },
  { name: 'Fitness Equipment', slug: 'fitness-equipment', description: 'Gear that keeps you moving' },
  { name: 'Kitchen Essentials', slug: 'kitchen-essentials', description: 'Tools every home cook needs' },
];
---

<BaseLayout
  title="Home Finds — Curated Home, Tech, Fitness &amp; Kitchen Products"
  description="Discover trending products across home decor, tech gadgets, fitness equipment, and kitchen essentials."
>
  <section class="pt-32 pb-20 md:pt-40 md:pb-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <span class="text-xs font-medium text-secondary uppercase tracking-[0.2em]">Curated Collection</span>
      <h1 class="mt-6 text-5xl md:text-7xl lg:text-8xl font-display font-bold text-dark tracking-tight leading-[1.1] md:leading-[1.05]">
        Discover Your Next<br class="hidden sm:block" /> Find
      </h1>
      <p class="mt-6 text-base md:text-lg text-secondary max-w-xl mx-auto leading-relaxed font-sans tracking-wide">
        Trending products across home decor, tech, fitness &amp; kitchen — curated daily.
      </p>
      <div class="mt-10 flex items-center justify-center gap-4">
        <a href="/categories/" class="btn-primary">Browse All</a>
        <a href="/about/" class="btn-outline">About</a>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 pb-20" data-reveal>
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-display font-semibold text-dark">Shop by Category</h2>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-5">
      {categories.map((cat, i) => (
        <div class={`revealed-delay-${i + 1}`} data-reveal>
          <CategoryCard name={cat.name} slug={cat.slug} description={cat.description} />
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 pb-24" data-reveal>
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-display font-semibold text-dark">Featured Products</h2>
    </div>
    <CategoryTabs active="all" />

    {allPosts.length > 0 ? (
      <div class="pinterest-grid">
        {allPosts.map(post => <ProductCard post={post} />)}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-secondary text-lg font-display">No products in this category yet</p>
        <p class="text-secondary/60 text-sm mt-2">Check back soon for new additions</p>
        <a href="/" class="inline-block mt-6 text-sm font-medium text-dark underline underline-offset-4 hover:opacity-60 transition-opacity">
          View all products &rarr;
        </a>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .pinterest-grid {
    columns: 1;
    column-gap: 1.5rem;
  }
  .pinterest-grid > * {
    break-inside: avoid;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 640px) {
    .pinterest-grid { columns: 2; }
  }
  @media (min-width: 1024px) {
    .pinterest-grid { columns: 3; }
  }
</style>
