---

const year = new Date().getFullYear();
---

<footer class="bg-dark text-gray-300 mt-20">
  <div class="max-w-6xl mx-auto px-4 py-16">
    <div class="grid md:grid-cols-3 gap-10">
      <div>
        <h3 class="text-xl font-display font-semibold text-white mb-3">
          Home <span class="text-brand-400">Finds</span>
        </h3>
        <p class="text-sm text-gray-400 leading-relaxed">
          Trending products across home decor, tech, fitness, and kitchen — curated daily.
        </p>
      </div>

      <div>
        <h4 class="text-xs font-semibold text-white uppercase tracking-widest mb-4">Quick Links</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/" class="text-gray-400 hover:text-white transition-colors">Home</a></li>
          <li><a href="/categories/" class="text-gray-400 hover:text-white transition-colors">Categories</a></li>
          <li><a href="/about/" class="text-gray-400 hover:text-white transition-colors">About</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold text-white uppercase tracking-widest mb-4">Niches</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/?niche=home-decor" class="text-gray-400 hover:text-white transition-colors">Home Decor</a></li>
          <li><a href="/?niche=tech-gadgets" class="text-gray-400 hover:text-white transition-colors">Tech Gadgets</a></li>
          <li><a href="/?niche=fitness-equipment" class="text-gray-400 hover:text-white transition-colors">Fitness Equipment</a></li>
          <li><a href="/?niche=kitchen-essentials" class="text-gray-400 hover:text-white transition-colors">Kitchen Essentials</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-700/50 text-xs text-gray-500 leading-relaxed space-y-3">
      <p>
        Home Finds is a participant in the Amazon Services LLC Associates Program, an affiliate advertising program designed to provide a means for sites to earn advertising fees by advertising and linking to Amazon.com. As an Amazon Associate, we earn from qualifying purchases.
      </p>
      <p>
        &copy; {year} Home Finds. All rights reserved.
      </p>
    </div>
  </div>
</footer>
