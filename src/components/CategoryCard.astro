---
interface Props {
  name: string;
  slug: string;
  description: string;
}

const { name, slug, description } = Astro.props;
---

<a
  href={`/?niche=${slug}`}
  class="block bg-white p-4 md:p-5 hover:shadow-soft transition-shadow duration-300 border border-border text-center"
>
  <h3 class="text-sm md:text-base font-display font-semibold text-dark">
    {name}
  </h3>
  <p class="text-xs text-secondary mt-1 leading-relaxed line-clamp-2">
    {description}
  </p>
</a>
