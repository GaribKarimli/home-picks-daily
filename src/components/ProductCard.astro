---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { data } = post;
const stars = Math.round(data.rating);
---

<a href={`/posts/${post.slug}/`} class="group block bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300">
  <div class="aspect-[4/3] overflow-hidden">
    <img
      src={data.image}
      alt={data.title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
  </div>

  <div class="p-4">
    <span class="inline-block text-xs font-medium text-brand-600 bg-brand-50 px-2.5 py-1 rounded-full">
      {data.category}
    </span>

    <h3 class="mt-2 text-base font-semibold text-dark line-clamp-2 leading-snug">
      {data.title}
    </h3>

    <div class="mt-2 flex items-center gap-1.5">
      <div class="flex text-amber-400 text-sm">
        {Array.from({ length: 5 }, (_, i) => (
          <span>{i < stars ? '★' : '☆'}</span>
        ))}
      </div>
      <span class="text-xs text-gray-400">({data.rating})</span>
    </div>

    <div class="mt-3 flex items-center justify-between">
      <span class="text-lg font-bold text-brand-600">{data.price}</span>
      <span class="text-sm font-medium text-gray-400 group-hover:text-brand-500 transition-colors">
        View Details &rarr;
      </span>
    </div>
  </div>
</a>
