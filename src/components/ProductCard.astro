---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { data } = post;
const stars = Math.round(data.rating);
---

<a href={`/posts/${post.slug}/`} class="group block bg-white rounded-3xl overflow-hidden shadow-soft hover:shadow-soft-lg transition-all duration-500">
  <div class="aspect-[4/3] overflow-hidden bg-brand-50">
    <img
      src={data.image}
      alt={data.title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
      loading="lazy"
    />
  </div>

  <div class="p-5">
    <span class="inline-block text-xs font-medium text-brand-600 bg-sage px-3 py-1.5 rounded-full">
      {data.category}
    </span>

    <h3 class="mt-3 text-lg font-display font-semibold text-dark leading-snug line-clamp-2">
      {data.title}
    </h3>

    <div class="mt-2 flex items-center gap-1.5">
      <div class="flex text-amber-400/80 text-sm">
        {Array.from({ length: 5 }, (_, i) => (
          <span>{i < stars ? '★' : '☆'}</span>
        ))}
      </div>
      <span class="text-xs text-dark/40">({data.rating})</span>
    </div>

    <div class="mt-4 flex items-center justify-between">
      <span class="text-xl font-display font-bold text-brand-500">{data.price}</span>
      <span class="text-sm font-medium text-dark/40 group-hover:text-brand-500 transition-colors">
        View Details &rarr;
      </span>
    </div>
  </div>
</a>
