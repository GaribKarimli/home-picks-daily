---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { data } = post;
---

<a href={`/posts/${post.slug}/`} class="group block bg-white hover:shadow-card-hover transition-all duration-500 animate-fade-in">
  <div class="aspect-[4/5] overflow-hidden bg-cream">
    <img
      src={data.image}
      alt={data.title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
      loading="lazy"
    />
  </div>

  <div class="p-5">
    <h3 class="text-sm font-display font-semibold text-dark leading-snug line-clamp-2 group-hover:opacity-70 transition-opacity duration-300">
      {data.title}
    </h3>

    <div class="mt-3 flex items-baseline justify-between">
      <span class="text-lg font-display font-bold text-dark tracking-tight">{data.price}</span>
    </div>

    {data.reviews > 0 && (
      <p class="mt-1.5 text-xs text-secondary tracking-wide">{data.reviews.toLocaleString()} reviews</p>
    )}
  </div>
</a>
