---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { data } = post;
---

<a href={`/posts/${post.slug}/`} class="group block bg-white overflow-hidden hover:shadow-soft transition-shadow duration-300">
  <div class="aspect-[4/5] overflow-hidden bg-cream">
    <img
      src={data.image}
      alt={data.title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
      loading="lazy"
    />
  </div>

  <div class="p-4">
    <h3 class="text-sm font-display font-semibold text-dark leading-snug line-clamp-2">
      {data.title}
    </h3>

    <div class="mt-2">
      <span class="text-base font-display font-bold text-dark">{data.price}</span>
    </div>

    {data.reviews > 0 && (
      <p class="mt-1 text-xs text-secondary">{data.reviews.toLocaleString()} reviews</p>
    )}
  </div>
</a>
